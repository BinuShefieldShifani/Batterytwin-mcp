# Copy to .env and adjust as needed.

# Ollama endpoint.
#   - Local (Ollama running on host):     http://localhost:11434
#   - Docker Compose (app -> ollama svc): http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Orchestration model. MUST support tool calling (>=7B recommended).
# Good 12 GB-friendly choices: llama3.1:8b (~4.7 GB Q4), qwen2.5:7b (~4.7 GB Q4).
# NOTE: tinyllama does NOT reliably do tool calls and will not drive the twin.
#OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL=qwen2.5:7b

# Low temperature keeps tool orchestration deterministic.
OLLAMA_TEMPERATURE=0.1
